{
  "compilerOptions": {
    "target": "es2022",
    "module": "Node16",
    "lib": ["es2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./",
    "resolveJsonModule": true,
    "moduleResolution": "Node16",
    "typeRoots": ["./node_modules/@types", "./src/types"]
  },
  "include": ["prisma.config.ts", "prisma/**/*.ts", "src/**/*.ts"]
}
